# Copy this file to `.env.smoke.local` and fill in the values for your AWS smoke environment.
SMOKE_AWS_REGION=us-east-2
SMOKE_TLS_DOMAIN=smoke.markcallen.dev
SMOKE_TLS_EMAIL=ops@example.com
SMOKE_INSTANCE_TYPE=t3.large
SMOKE_NAME_PREFIX=aadm-smoke
SMOKE_SPOT_MAX_PRICE=
SMOKE_AAB_NPM_PACKAGE=ai-agent-browser
SMOKE_WEB_INGRESS_CIDR=
SMOKE_PUBLIC_WEB_INGRESS=false
SMOKE_TLS_STAGING=false
SMOKE_DESTROY_DESKTOP=false

# Manager bind
AADM_HOST=127.0.0.1
AADM_PORT=8899

# Optional auth. If set, requests must send: Authorization: Bearer <token>
AADM_AUTH_TOKEN=

# Public base URL used to generate noVNC links (what YOU open in your browser)
# Example: https://mybox.example.com
AADM_PUBLIC_BASE_URL=https://host.example.com

# Nginx snippets
AADM_NGINX_SNIPPET_DIR=/etc/nginx/conf.d/agent-desktops
AADM_STATE_DIR=./data

# Port/display ranges (inclusive)
# Ports are display-derived:
# wsPort  = AADM_WEBSOCKIFY_PORT_MIN + (display - AADM_DISPLAY_MIN)
# cdpPort = AADM_CDP_PORT_MIN + (display - AADM_DISPLAY_MIN)
# aabPort = AADM_AAB_PORT_MIN + (display - AADM_DISPLAY_MIN)
# Ensure each *_PORT_MAX can cover the display span.
AADM_DISPLAY_MIN=1
AADM_DISPLAY_MAX=50

AADM_WEBSOCKIFY_PORT_MIN=6081
AADM_WEBSOCKIFY_PORT_MAX=6150

AADM_CDP_PORT_MIN=9222
AADM_CDP_PORT_MAX=9299

AADM_AAB_PORT_MIN=8765
AADM_AAB_PORT_MAX=8849

# systemd template unit names
AADM_UNIT_VNC=vnc@
AADM_UNIT_WEBSOCKIFY=websockify@
AADM_UNIT_CHROME=chrome@
AADM_UNIT_AAB=aab@

# Paths to commands (override if needed)
AADM_NGINX_BIN=/usr/sbin/nginx
AADM_SYSTEMCTL_BIN=/bin/systemctl

# Default desktop URL path pattern
AADM_NOVNC_PATH_PREFIX=/desktop

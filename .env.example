# Manager bind
AADM_HOST=127.0.0.1
AADM_PORT=8899

# Optional auth. If set, requests must send: Authorization: Bearer <token>
AADM_AUTH_TOKEN=

# Optional route protection for externally exposed desktop routes.
# `none` keeps current behavior. `auth_request` requires a verifier URL.
# `token` uses manager-issued secure access URLs and a shared secret.
AADM_DESKTOP_ROUTE_AUTH_MODE=none
AADM_DESKTOP_ROUTE_AUTH_REQUEST_URL=
# Comma-separated request headers to forward to the auth verifier, for example:
# AADM_DESKTOP_ROUTE_AUTH_REQUEST_HEADERS=x-auth-request-user,x-orchestrator-token
AADM_DESKTOP_ROUTE_AUTH_REQUEST_HEADERS=
# Shared secret and TTL for token-backed secure access URLs.
AADM_DESKTOP_ROUTE_TOKEN_SECRET=
AADM_DESKTOP_ROUTE_TOKEN_TTL_SECONDS=900

# Optional HTTPS deployment variables for certbot + nginx HTTP-01.
# The smoke/deployment helper uses these values when you pass --enable-https.
AADM_TLS_ENABLED=false
AADM_TLS_DOMAIN=
AADM_TLS_EMAIL=
AADM_TLS_STAGING=false

# Public base URL used to generate noVNC links (what YOU open in your browser)
# Example: https://mybox.example.com
AADM_PUBLIC_BASE_URL=https://host.example.com

# Nginx snippets
AADM_NGINX_SNIPPET_DIR=/etc/nginx/conf.d/agent-desktops
AADM_STATE_DIR=./data

# Port/display ranges (inclusive)
# Ports are display-derived:
# wsPort  = AADM_WEBSOCKIFY_PORT_MIN + (display - AADM_DISPLAY_MIN)
# cdpPort = AADM_CDP_PORT_MIN + (display - AADM_DISPLAY_MIN)
# aabPort = AADM_AAB_PORT_MIN + (display - AADM_DISPLAY_MIN)
# Ensure each *_PORT_MAX can cover the display span.
AADM_DISPLAY_MIN=1
AADM_DISPLAY_MAX=50

AADM_WEBSOCKIFY_PORT_MIN=6081
AADM_WEBSOCKIFY_PORT_MAX=6150

AADM_CDP_PORT_MIN=9222
AADM_CDP_PORT_MAX=9299

AADM_AAB_PORT_MIN=8765
AADM_AAB_PORT_MAX=8849

# systemd template unit names
AADM_UNIT_VNC=vnc@
AADM_UNIT_WEBSOCKIFY=websockify@
AADM_UNIT_CHROME=chrome@
AADM_UNIT_AAB=aab@

# Paths to commands (override if needed)
AADM_NGINX_BIN=/usr/sbin/nginx
AADM_SYSTEMCTL_BIN=/bin/systemctl

# Default desktop URL path pattern
AADM_NOVNC_PATH_PREFIX=/desktop

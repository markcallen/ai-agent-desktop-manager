{
  "name": "ai-agent-desktop-manager",
  "version": "0.1.1",
  "private": true,
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "package:release": "bash ./scripts/package-release.sh",
    "start": "node dist/index.js",
    "cli": "tsx src/cli/aadm.ts",
    "aab-console": "tsx src/cli/aab-console.ts",
    "test": "node --import tsx --test test/**/*.test.ts",
    "test:coverage": "node --import tsx --experimental-test-coverage --test test/**/*.test.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prettier": "prettier . --check",
    "prettier:fix": "prettier . --write"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "proper-lockfile": "^4.1.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.10.2",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "tsx": "^4.16.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.58.0"
  }
}
